# ---------------------------------------------------------------------------
# BankIQ environment configuration
# Copy this file to `.env` (in the project root or in `backend/`) and fill in
# your real values. Never commit the populated `.env` file.
# ---------------------------------------------------------------------------

# Groq Cloud API key (https://console.groq.com/keys). Required for live LLM
# reasoning. Without it the pipeline returns a graceful degraded report.
GROQ_API_KEY=gsk_your_key_here
# Groq model id used by every agent. `llama-3.3-70b-versatile` is a strong,
# reliable default. Stronger alternative: `openai/gpt-oss-120b`.
GROQ_MODEL=llama-3.3-70b-versatile

# Groq OpenAI-compatible base URL. Override only if Groq changes the endpoint.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Sampling temperature for agent reasoning. 0.0 = deterministic (recommended so
# the planted causal story surfaces reliably).
LLM_TEMPERATURE=0.0

# Per-request LLM timeout in seconds.
LLM_REQUEST_TIMEOUT_SECONDS=60

# FastAPI server bind host/port.
BANKIQ_HOST=127.0.0.1
BANKIQ_PORT=8000

# Comma-separated list of allowed CORS origins (the Vite dev server by default).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
